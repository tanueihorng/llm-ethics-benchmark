{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dashboard",
      "runtimeExecutable": "streamlit",
      "runtimeArgs": [
        "run",
        "dashboard/app.py",
        "--server.headless",
        "true",
        "--server.port",
        "8503"
      ],
      "port": 8503
    },
    {
      "name": "docs-static",
      "runtimeExecutable": "sh",
      "runtimeArgs": [
        "-c",
        "exec python3 -m http.server \"${PORT:-8618}\" --directory docs"
      ],
      "port": 8618,
      "autoPort": true
    }
  ]
}