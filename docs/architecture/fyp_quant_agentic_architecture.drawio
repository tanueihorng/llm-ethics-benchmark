        <mxCell value="fyp_quant: Agentic Research Harness Architecture&lt;br&gt;&lt;font style='font-size: 16px'&gt;Repo-native memory, isolated subagents, verified evidence, and report generation&lt;/font&gt;" style="rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#0F3B66;strokeColor=#0F3B66;fontColor=#FFFFFF;fontFamily=Inter;fontSize=28;fontStyle=1;spacingLeft=24;spacingTop=20;" vertex="1" parent="1" id="title">
