__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.DS_Store

# Claude Code machine-local settings (never commit); the project-level
# skill under .claude/skills/ IS versioned and tracked.
.claude/settings.local.json

# Run outputs (per-prompt + summaries)
results/**/raw.jsonl
results/**/raw.v2.jsonl
results/**/summary.json
results/**/submitted_jobs.json
results/**/check_status.json
results/summary/*.csv
# Note: results/analysis/*.{json,csv} are intentionally tracked — they are the
# pipeline ground truth (pair_interpretations, pairwise_deltas, summary) and
# the source of the interpretation labels that appear in the FYP report.

# T18 multi-seed sensitivity arm: raw generations (contain harmful prompt/
# response text) and judge sidecars stay local. Only the redacted aggregate
# results/analysis/sensitivity_multiseed.{json,csv} is committed.
results_sensitivity/
# T31/D39: 512-token multi-seed arm (same local-only policy as results_sensitivity/)
results_sensitivity_512/

# T31/D39 512-token generation-length rerun arm: same policy as results/ —
# raw generations + summaries stay local (harmful text), redacted judge sidecars
# and results_512/analysis/* are the only tracked artifacts.
results_512/**/raw.jsonl
results_512/**/raw.v2.jsonl
results_512/**/summary.json
results_512/**/submitted_jobs.json
results_512/**/check_status.json
results_512/summary/*.csv
results_512/slurm_logs*/

# SLURM logs for any cluster variant (slurm_logs, slurm_logs_tc1, ...)
results/slurm_logs*/

# Generated SLURM artifacts
slurm/*.json
slurm/jobs*/manifest.json
slurm/jobs*/submitted_jobs.json
# slurm/jobs/ is the legacy job directory (pre-TC1 restructure); ignore its sbatch files.
# Active jobs live in slurm/jobs_tc1/ and slurm/jobs_tc1_smoke/ (tracked in git).
slurm/jobs/*.sbatch

# Editor / IDE / OS caches not relevant to this repo
.swift-cache/
pdfthumbs/
terminal_log*.txt

# Word lock files (created by Word when a doc is open)
~$*.docx
~$*.html

# Note: we DO commit .docx and .html under docs/ — the FYP report is a
# deliverable and docs/archive/ history is preserved in git.

# Supervisor correspondence drafts — keep local, never commit
docs/email_*.md

# Python packaging build artifacts (from pip install -e .)
*.egg-info/

# Node dependencies — local @resvg/resvg-js (figure rasteriser for
# scripts/build_agentic_report.js). package.json + package-lock.json ARE tracked
# so the dependency is recorded; restore the platform binary with `npm install`.
node_modules/

# Human-label audit: annotation sheet contains raw prompt/response text — local only.
# Only the redacted aggregate results/analysis/human_validation.json is committed.
human_labels/

# FYP submission staging package (contains private email drafts) — keep local
fyp_submission/

# Dashboard (dashboard/app.py) scratch outputs: user-scaffolded configs and the
# sbatch they generate are working files, not committed artifacts. Force-add a
# specific one (git add -f) if you decide to keep it.
configs/generated/
slurm/jobs_generated/
results_dev/
