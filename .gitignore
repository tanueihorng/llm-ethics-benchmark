__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.DS_Store

# Claude Code machine-local settings (never commit); the project-level
# skill under .claude/skills/ IS versioned and tracked.
.claude/settings.local.json

# Run outputs (per-prompt + summaries)
results/**/raw.jsonl
results/**/raw.v2.jsonl
results/**/summary.json
results/**/submitted_jobs.json
results/**/check_status.json
results/summary/*.csv
# Note: results/analysis/*.{json,csv} are intentionally tracked — they are the
# pipeline ground truth (pair_interpretations, pairwise_deltas, summary) and
# the source of the interpretation labels that appear in the FYP report.

# T18 multi-seed sensitivity arm: raw generations (contain harmful prompt/
# response text) and judge sidecars stay local. Only the redacted aggregate
# results/analysis/sensitivity_multiseed.{json,csv} is committed.
results_sensitivity/

# SLURM logs for any cluster variant (slurm_logs, slurm_logs_tc1, ...)
results/slurm_logs*/

# Generated SLURM artifacts
slurm/*.json
slurm/jobs*/manifest.json
slurm/jobs*/submitted_jobs.json
# slurm/jobs/ is the legacy job directory (pre-TC1 restructure); ignore its sbatch files.
# Active jobs live in slurm/jobs_tc1/ and slurm/jobs_tc1_smoke/ (tracked in git).
slurm/jobs/*.sbatch

# Editor / IDE / OS caches not relevant to this repo
.swift-cache/
pdfthumbs/
terminal_log*.txt

# Word lock files (created by Word when a doc is open)
~$*.docx
~$*.html

# Note: we DO commit .docx and .html under docs/ — the FYP report is a
# deliverable and docs/archive/ history is preserved in git.
